# ============================================================================
# Akash AI Pro Gateway -- Environment Variables
# Copy this file to `.env` and adjust values for your environment.
# NEVER commit a real `.env` file to version control.
# ============================================================================

APP_NAME="Akash AI Pro - Secure Enterprise API Gateway"
ENVIRONMENT=production
DEBUG=false

# --- JWT ---------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=akash-ai-gateway

# --- CORS ---------------------------------------------------------------------
CORS_ORIGINS=["*"]

# --- Redis ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Rate Limiting -------------------------------------------------------------
RATE_LIMIT_FREE_TIER_CAPACITY=5
RATE_LIMIT_FREE_TIER_REFILL_PER_MIN=5
RATE_LIMIT_PREMIUM_TIER_CAPACITY=100
RATE_LIMIT_PREMIUM_TIER_REFILL_PER_MIN=100

# --- DDoS Guard -----------------------------------------------------------------
DDOS_IP_WINDOW_SECONDS=10
DDOS_IP_MAX_REQUESTS=30
DDOS_IP_BLOCK_SECONDS=300

# --- Circuit Breaker --------------------------------------------------------------
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=2

# --- Mock AI Service -----------------------------------------------------------
MOCK_AI_TIMEOUT_SECONDS=2.5
MOCK_AI_FAILURE_RATE=0.15
MOCK_AI_MIN_LATENCY_MS=150
MOCK_AI_MAX_LATENCY_MS=3200
